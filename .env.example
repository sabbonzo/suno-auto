# ── Configurazione richiesta ──────────────────────────────────────────────────
# Copia in .env e compila con i tuoi valori

# Credenziali Google (solo per login automatico)
GMAIL_USER=your@email.com
GMAIL_PASSWORD=

# Directory base
MUSIC_DIR=./music
ORACLE_DIR=./oracle

# Chrome
CHROME_EXE=C:/Program Files/Google/Chrome/Application/chrome.exe
CHROME_PROFILE=./chrome_profile

# Gumroad
GUMROAD_COOKIES=./gumroad_cookies.json
GUMROAD_PRODUCT_ID=YOUR_PRODUCT_ID
GUMROAD_USERNAME=your_username

# Google Drive
GDRIVE_LOCAL=G:/Il mio Drive

# Suno
SUNO_PROFILE=./suno_profile
DAILY_LIMIT=6

# Output
OUTPUT_DIR=./output
